# BuildOwnRAG environment. Copy to .env and fill in the generated secrets.
# API keys and the admin account are set in the setup wizard on first run.

# Image version to pull ("latest" or a release version like 1.0.0)
IMAGE_TAG=latest

# Ports on the host
APP_PORT=8080
FRONTEND_PORT=3000
SETUP_PORT=8081

# Database
POSTGRES_DB=buildownrag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Secrets (generate these — see README)
JWT_SECRET=
JWT_ISSUER=BuildOwnRAG
JWT_AUDIENCE=BuildOwnRAG
ENCRYPTION_KEY=     # must be exactly 32 characters
ENCRYPTION_IV=      # must be exactly 16 characters

# CORS (tighten to your domain in production)
ALLOWED_ORIGINS=*

# AI provider (usually set via the setup wizard, not here)
LLM_PROVIDER=Gemini
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=
OPENAI_API_KEY=

IS_SETUP_COMPLETED=false
