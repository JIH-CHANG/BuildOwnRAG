# BuildOwnRAG — minimal .env for first boot.
# Copy to .env and set POSTGRES_PASSWORD. The setup wizard (http://localhost:8081)
# generates and writes everything else (JWT, encryption keys, AI provider/keys,
# admin account) into .env on completion — you do not fill those in by hand.

# Database password (required before first boot; enter the SAME value in the wizard)
POSTGRES_PASSWORD=

# Optional: pin an image version (defaults to this release's version), or remap ports
# IMAGE_TAG=1.0.0
# APP_PORT=8080
# FRONTEND_PORT=3000
# SETUP_PORT=8081

# Ollama (local LLM): set this if using Ollama installed on the host machine.
# Docker Desktop (Windows/Mac): host.docker.internal resolves to the host.
# Linux Docker: use the host's LAN IP instead (e.g. 192.168.1.x).
# LLM_OLLAMA_BASE_URL=http://host.docker.internal:11434

# Data directory: where PostgreSQL / Qdrant / Redis store their files (default: ./data next to this file).
# Use an absolute path to store data on a different drive, e.g.:
#   Windows: DATA_DIR=D:/buildownrag-data
#   Linux:   DATA_DIR=/mnt/data/buildownrag
# DATA_DIR=./data
