# BuildOwnRAG — minimal .env for first boot.
# Copy to .env and set POSTGRES_PASSWORD. The setup wizard (http://localhost:8081)
# generates and writes everything else (JWT, encryption keys, AI provider/keys,
# admin account) into .env on completion — you do not fill those in by hand.

# Database password (required before first boot; enter the SAME value in the wizard)
POSTGRES_PASSWORD=

# Optional: pin an image version (defaults to this release's version), or remap ports
# IMAGE_TAG=1.0.0
# APP_PORT=8080
# FRONTEND_PORT=3000
# SETUP_PORT=8081
